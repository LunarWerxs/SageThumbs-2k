<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparse identity package for SageThumbs 2K.

  Grants package identity to the unpackaged Win32 DLL/EXE (which live in the
  external location passed at registration) so Windows 11 will surface the
  IExplorerCommand verb in the modern context menu and load the thumbnail
  provider via the COM surrogate. Register (dev) with:

    Add-AppxPackage -Register packaging\AppxManifest.xml -ExternalLocation <dir-with-dll+exe>

  (Developer Mode must be on; no signing/makeappx needed for loose registration.
  A signed, packed .msix for distribution needs the Windows SDK — Phase 2/M7.)
-->
<Package
  IgnorableNamespaces="uap uap3 uap10 rescap com desktop2 desktop4 desktop5"
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:desktop2="http://schemas.microsoft.com/appx/manifest/desktop/windows10/2"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5">

  <Identity Name="SageThumbs2K" Publisher="CN=SageThumbs2K" Version="1.0.1.0" ProcessorArchitecture="neutral" />

  <Properties>
    <DisplayName>SageThumbs 2K</DisplayName>
    <PublisherDisplayName>SageThumbs 2K</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <rescap:Capability Name="unvirtualizedResources" />
  </Capabilities>

  <Applications>
    <Application Id="SageThumbs2K" Executable="SageThumbs2K.exe"
                 uap10:TrustLevel="mediumIL" uap10:RuntimeBehavior="win32App">
      <uap:VisualElements AppListEntry="none" DisplayName="SageThumbs 2K"
                          Description="Modern thumbnails and context menu for image files"
                          BackgroundColor="transparent"
                          Square150x150Logo="Assets\Square150x150Logo.png"
                          Square44x44Logo="Assets\Square44x44Logo.png" />
      <Extensions>

        <!-- COM server: the IExplorerCommand coclasses hosted out-of-process via the
             surrogate. The CLSIDs match guids.rs (pinned by the
             manifest_clsids_match_known test). -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <!-- IExplorerCommand context-menu verbs, activated out-of-proc in
                 dllhost via the generic surrogate (PowerToys' PowerRename uses
                 exactly this). The thumbnail provider is NOT packaged: it is
                 registered classically via DllRegisterServer (regsvr32, elevated),
                 the proven path that doesn't need package identity.

                 D4F1C8A2 is the (currently dormant) root "SageThumbs 2K" flyout — kept
                 registered for COM activation but with NO verb pointing at it, so it
                 never renders (re-adding a root verb would double-list "SageThumbs 2K"
                 next to the classic handler; see the FileExplorerContextMenus note below).
                 The four 1C7F…/2D8A…/3E9B…/4FAC… coclasses are the top-level quick verbs. -->
            <com:SurrogateServer DisplayName="SageThumbs 2K Context Menu">
              <com:Class Id="D4F1C8A2-3E7B-4A96-8C0F-6B1E2D9A4C57" Path="sagethumbs2k.dll" ThreadingModel="STA" />
              <com:Class Id="1C7F4E2A-9D63-4B85-A0F1-7E2C5B9D4A60" Path="sagethumbs2k.dll" ThreadingModel="STA" />
              <com:Class Id="2D8A5F3B-0E74-4C96-B1A2-8F3D6CAE5B71" Path="sagethumbs2k.dll" ThreadingModel="STA" />
              <com:Class Id="3E9B6A4C-1F85-4DA7-C2B3-9A4E7DBF6C82" Path="sagethumbs2k.dll" ThreadingModel="STA" />
              <com:Class Id="4FAC7B5D-2096-4EB8-D3C4-AB5F8ECA7D93" Path="sagethumbs2k.dll" ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

        <!-- (Thumbnails are handled by the classic regsvr32 registration, not
             the package — see register.rs.) -->

        <!-- Modern (Win11 new-menu) QUICK VERBS.

             Convert into ▸ / Convert… / Resize ▸ / Rotate ▸ surfaced as their OWN
             top-level entries on the compact Win11 context menu, one click away — the
             modern twin of the classic "quick verbs on main menu" Option. Each Verb
             points at its own coclass (command.rs::QUICK_VERBS ↔ guids.rs, pinned by
             the quick_verbs_match_quick_keys + manifest_clsids_match_known tests). Each
             verb's GetState is HIDDEN unless EnableMenu AND MenuQuickVerbs are on AND the
             selection holds a supported, non-audio image — so they're absent by default
             and vanish when the toggle is off, never cluttering the menu uninvited.

             We deliberately do NOT declare a verb for the ROOT "SageThumbs 2K" flyout
             (D4F1C8A2): a packaged verb is bridged by Windows into the legacy "Show more
             options" menu, and a root "SageThumbs 2K" there would sit next to our own
             classic IContextMenu handler's "SageThumbs 2K" — listing it TWICE. The quick
             verbs are bridged too, but the classic handler detects the package
             (settings::modern_menu_active, set by the installer) and OMITS its own
             top-level quick-verb copies, so they're listed exactly once in the legacy
             menu. The full flyout + owner-drawn preview stay on the classic handler.

             Type="*" (all files) keeps the manifest from enumerating 300+ formats; the
             per-verb GetState gate does the real filtering. -->
        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type="*">
              <desktop5:Verb Id="SageThumbs2KConvertInto"   Clsid="1C7F4E2A-9D63-4B85-A0F1-7E2C5B9D4A60" />
              <desktop5:Verb Id="SageThumbs2KConvertDialog" Clsid="2D8A5F3B-0E74-4C96-B1A2-8F3D6CAE5B71" />
              <desktop5:Verb Id="SageThumbs2KResize"        Clsid="3E9B6A4C-1F85-4DA7-C2B3-9A4E7DBF6C82" />
              <desktop5:Verb Id="SageThumbs2KRotate"        Clsid="4FAC7B5D-2096-4EB8-D3C4-AB5F8ECA7D93" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>

      </Extensions>
    </Application>
  </Applications>
</Package>
