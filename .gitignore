/target
**/*.rs.bk
# Cargo.lock IS committed — this ships binaries, so builds must be reproducible.
*.pdb
# Signing material — never commit a private key or cert
*.msix
*.pfx
*.cer
*.snk
*.p12
*.pem
*.key

# Release pipeline artifacts (regenerated by scripts/build-release.ps1)
# compiled installers — attach to GitHub Releases instead
/dist/
# staged payload incl. the bundled ImageMagick
/packaging/stage/
.saydeploy/
test/

# Editor / OS / local junk (.vscode/settings.json is intentionally tracked)
.DS_Store
Thumbs.db
*.swp
*~
.idea/
*.code-workspace

# Local env / secrets
.env
*.local

# Private planning/notes docs (owner-only) — previously hidden only via the local,
# unshared .git/info/exclude, which doesn't protect a fresh clone or `git add -A`.
# Root-anchored so these only match the top-level files, not e.g. docs/ or examples/.
/CLAUDE.md
/TODO.md
/ROADMAP.md
/CODE-REVIEW-BACKLOG.md
/NEWDO.md
/NEWDO-2.md
/MAINTAINABILITY-AUDIT.md
/checkme.md
/VIDEO-THUMBNAIL-FIX.md
/SEO_AND_OPEN_GRAPH.md
/BREADCRUMB.md
/TODO-menu-reorder.md
/TODO-mysticthumbs-features.md
/TODO-mysticthumbs-parity.md

# Private admin/sponsor tooling + local scratch corpus tooling (never publish)
/admin_dashboard.py
/admin_dashboard.token
/sponsor_config.json
/push_sponsors.py
/push_to_vt.py
/push_to_vt_test.py
/examples/
/scripts/fill-audio-real.ps1
/scripts/build-corpus-real.ps1
/scripts/private/
/packaging/analytics/

# Owner's local to-do scratch dir
/to-do/

# AI coding assistant local config/session state — never publish
/.claude/
# cargo-mutants scratch (mutation-testing results; regenerated every run)
/mutants.out/
/mutants.out.old/
